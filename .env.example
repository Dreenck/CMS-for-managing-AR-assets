# PostgreSQL Database Settings
POSTGRES_USER=cms_admin
POSTGRES_PASSWORD=cms_password
POSTGRES_DB=cms_database
POSTGRES_HOST=postgres_db
POSTGRES_PORT=5432
# MinIO (Local S3 Storage) Settings
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password

# MinIO / S3 Configuration
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET_NAME=ar-assets

# Clerk Authentication (Optional, leave blank to bypass auth for local development)
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=

# Backend CORS Allowed Origins (comma-separated list of domains)
CORS_ORIGINS=http://localhost:5173

# Frontend API Base URL (point to your backend service url)
VITE_API_BASE_URL=http://localhost:8000